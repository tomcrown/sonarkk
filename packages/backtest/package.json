{
  "name": "@sonarkk/backtest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./lib": "./dist/lib.js"
  },
  "typesVersions": {
    "*": {
      "lib": ["./dist/lib.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "run:backtest": "tsx src/index.ts",
    "run:regime": "tsx src/analysis/run.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "@sonarkk/core": "workspace:*",
    "dotenv": "^16.6.1",
    "pino": "^9.14.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.4"
  }
}
