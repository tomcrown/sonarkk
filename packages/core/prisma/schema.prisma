// Sonark data layer — Supabase Postgres via Prisma
// Run: pnpm --filter @sonarkk/core exec prisma db push

generator client {
  provider = "prisma-client-js"
}

// Local/CI: provider=sqlite, DATABASE_URL="file:./dev.db"
// Production (Supabase): change provider to "postgresql" and set DATABASE_URL.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Strategy registry ----
// StrategyType values: PLP_SUPPLIER | HEDGED_PLP | SMART_VAULT |
//   PRINCIPAL_PROTECTED | RANGE_ROLL | VOL_TARGETED_RANGE | CROSS_VENUE_ARB
// Stored as String for SQLite compat; Postgres migration will add a CHECK constraint.
model Strategy {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  type        String   // StrategyType enum value
  active      Boolean  @default(false)
  vaultId     String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  backtestResults BacktestResult[]
  keeperRuns      KeeperRun[]
  leaderboard     LeaderboardEntry?
}

// ---- Backtest results (Phase 1 output) ----
model BacktestResult {
  id            String   @id @default(cuid())
  strategyId    String
  strategy      Strategy @relation(fields: [strategyId], references: [id])
  runAt         DateTime @default(now())
  periodStart   DateTime
  periodEnd     DateTime
  totalRounds   Int
  winRate       Float
  avgPnlBps     Float
  maxDrawdownBps Float
  spreadCostBps Float
  sharpeRatio   Float?
  survives      Boolean
  notes         String?

  @@index([strategyId])
}

// ---- Keeper execution log (Phase 4) ----
// KeeperAction values: SUPPLY | WITHDRAW | MINT | MINT_RANGE | REDEEM | REDEEM_RANGE | HEDGE_SPOT | SKIP
model KeeperRun {
  id           String   @id @default(cuid())
  strategyId   String
  strategy     Strategy @relation(fields: [strategyId], references: [id])
  oracleId     String
  action       String   // KeeperAction enum value
  txDigest     String?  @unique
  success      Boolean
  errorMsg     String?
  gasUsed      BigInt?
  executedAt   DateTime @default(now())

  @@index([strategyId])
  @@index([oracleId])
}

// ---- Leaderboard (Phase 5) ----
// Populated by the leaderboard job (packages/keeper/src/jobs/leaderboard.ts).
// Ranking key: totalReturnPct descending.
// APY caveat is mandatory on every consumer of rollingApyPct —
// trader volume on testnet is minimal; numbers are not indicative of mainnet returns.
model LeaderboardEntry {
  id                   String   @id @default(cuid())
  strategyId           String   @unique
  strategy             Strategy @relation(fields: [strategyId], references: [id])
  rank                 Int
  tvlDusdc             BigInt   @default(0)
  totalReturnPct       Float?
  rollingApyPct        Float?
  apyCaveat            String?
  totalCycles          Int      @default(0)
  successfulCycles     Int      @default(0)
  skippedCycles        Int      @default(0)
  maxDrawdownPct       Float?
  avgCoverageRatioPct  Float?
  volArbCycleCount     Int      @default(0)
  volArbAvgEdgePct     Float?
  copiers              Int      @default(0)
  updatedAt            DateTime @updatedAt
}

// ---- Copy / provenance ----
// Fee model: 10% platform performance fee + 5% copy fee — tracked but not enforced on testnet.
model CopyRelation {
  id                    String    @id @default(cuid())
  followerAddr          String
  strategyId            String
  strategySnapshot      String?   // JSON: strategy config at copy time
  isActive              Boolean   @default(true)
  copiedAt              DateTime  @default(now())
  uncopiedAt            DateTime?
  performanceFeeAccrued Float     @default(0.0) // platform 10% performance fee (DUSDC)
  copyFeeAccrued        Float     @default(0.0) // copy 5% fee (DUSDC)

  @@unique([followerAddr, strategyId])
  @@index([strategyId])
  @@index([followerAddr])
}

// ---- Phase 4: On-chain portfolio registry ----
// Keeper processes every Portfolio where isActive = true each expiry cycle.
model Portfolio {
  id               String   @id @default(cuid())
  objectId         String   @unique   // Sui object ID of SonarkPortfolio<DUSDC>
  ownerAddress     String
  policyCapId      String             // PolicyCap object ID (keeper reads to check validity)
  strategy         String   // StrategyType enum value
  isActive         Boolean  @default(true)
  // For Hedged-PLP: scales the hedge notional relative to active PLP position.
  // 1.0 = full hedge of active notional. Capped by 50% of availableBalance.
  hedgeMultiplier  Float    @default(1.0)
  // PredictManager object ID — bettor strategies (⑤⑥⑦) only. null for house strategies.
  managerId        String?
  // VaultConfig this portfolio belongs to (null = standalone portfolio).
  vaultConfigId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cycles        KeeperCycle[]
  openPositions OpenPosition[]
  vaultConfig   VaultConfig?   @relation(fields: [vaultConfigId], references: [id])
}

// ---- Phase 6: Open bettor positions ----
// Tracks live binary/range positions for settlement in the next cycle.
// Populated after mint/mint_range PTBs; consumed by settlement step.
// Deleted when the position settles (payout recorded in KeeperCycle).
model OpenPosition {
  id            String   @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id])
  positionType  String   // 'binary' | 'range'
  oracleId      String   // oracle the position was minted against
  marketKey     String   // on-chain key for redeem_permissionless / redeem_range
  quantityRaw   BigInt   // contracts held (for binary) or notional raw (for range)
  notionalRaw   BigInt   // DUSDC paid as premium
  expiryMs      BigInt   // oracle expiry ms — when to settle
  mintTxDigest  String?
  settledAt     DateTime?
  payoutRaw     BigInt   @default(0)
  createdAt     DateTime @default(now())

  @@index([portfolioId])
  @@index([oracleId])
  @@index([expiryMs])
}

// ---- Phase 6: Named bot / vault config ----
// A VaultConfig is a named collection of portfolios with defined allocations.
// It is the unit for leaderboard display and copy-trading.
// One VaultConfig → many Portfolios (each a different strategy).
model VaultConfig {
  id              String   @id @default(cuid())
  name            String                         // user-chosen name e.g. "Alice's Bot"
  creatorAddress  String
  // JSON array: [{ strategy: 'HEDGED_PLP', allocationBps: 6000 }, ...]
  // allocationBps sums to 10000 (100%). Defines the intended mix.
  allocations     String   @default("[]")
  isPublic        Boolean  @default(true)        // visible in leaderboard
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  portfolios      Portfolio[]
  leaderboard     VaultLeaderboardEntry?
  copies          VaultCopyRelation[]   @relation("originalVault")
  copiedFrom      VaultCopyRelation[]   @relation("copiedVault")
}

// ---- Phase 6: Vault-level leaderboard ----
// One row per VaultConfig. Combined NAV = sum of all constituent portfolios.
// Ranking key: totalReturnPct descending.
model VaultLeaderboardEntry {
  id                String   @id @default(cuid())
  vaultConfigId     String   @unique
  vaultConfig       VaultConfig @relation(fields: [vaultConfigId], references: [id])
  rank              Int
  combinedTvlRaw    BigInt   @default(0)   // sum of portfolio NAVs (raw DUSDC)
  totalReturnPct    Float?
  rollingApyPct     Float?
  apyCaveat         String?
  totalCycles       Int      @default(0)
  successfulCycles  Int      @default(0)
  copierCount       Int      @default(0)
  updatedAt         DateTime @updatedAt
}

// ---- Phase 6: Vault-level copy relation ----
// Tracks who copied which VaultConfig. On copy, keeper deploys matching portfolios
// for the follower (same strategy mix) in a single PTB.
model VaultCopyRelation {
  id               String    @id @default(cuid())
  followerAddr     String
  originalVaultId  String
  originalVault    VaultConfig @relation("originalVault", fields: [originalVaultId], references: [id])
  // The follower's VaultConfig created for them by the copy action.
  copiedVaultId    String?
  copiedVault      VaultConfig? @relation("copiedVault", fields: [copiedVaultId], references: [id])
  // Snapshot of the creator's allocations at copy time.
  allocationSnapshot String?
  isActive         Boolean   @default(true)
  copiedAt         DateTime  @default(now())
  uncopiedAt       DateTime?

  @@unique([followerAddr, originalVaultId])
  @@index([originalVaultId])
  @@index([followerAddr])
}

// ---- Phase 4: Per-expiry keeper execution log ----
// Primary idempotency key: (portfolioId, expiryMs).
// The unique constraint ensures that restarting the keeper mid-cycle
// will skip already-processed portfolio+expiry combinations.
model KeeperCycle {
  id          String   @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  oracleId    String
  expiryMs    BigInt   // oracle expiry timestamp ms — idempotency key component

  // Outcome
  status      String   // done | skipped | error
  skipReason  String?
  errorMsg    String?

  // NAV snapshot (before cycle)
  navPerShareBefore  BigInt?
  navPerShareAfter   BigInt?
  quoteBalanceRaw    BigInt?
  lpBalanceRaw       BigInt?
  lpValueRaw         BigInt?
  bettorMtmRaw       BigInt?
  totalNavRaw        BigInt?
  vaultValueRaw      BigInt?
  plpTotalSupplyRaw  BigInt?

  // Entry guard
  atmVol             Float?
  atmSpread          Float?
  entryGuardSkipped  Boolean  @default(false)

  // Execution
  settleTxDigest     String?
  supplyTxDigest     String?

  // Hedge (strategy ② Hedged-PLP)
  hedgeDirection       String?   // long | short | none
  hedgeSizeDbtc        Float?
  hedgeNotionalDusdc   Float?
  idealHedgeNotional   Float?
  coverageRatioPct     Float?    // Phase 5 reads this to show hedge coverage to users
  hedgeTxDigest        String?
  hedgeSkipReason      String?   // set when hedge was skipped (no BalanceManager, math skip, etc.)
  isPartialHedge       Boolean  @default(false)
  hedgeBudgetDusdc     Float?

  // Delta source — 'positions' = real PredictManager read, 'proxy' = 55/45 LP value approximation.
  // Phase 5 Task 1: always 'positions' once predict-manager.ts is wired in.
  deltaSource          String?

  // Vol-arb cross-venue fields (Phase 5 Task 6).
  // volArbSource: 'hyperliquid' | 'polymarket' | 'realized_vol_fallback'
  volArbSource              String?
  volArbPredictImpliedVol   Float?
  volArbReferenceImpliedVol Float?
  volArbEdgePct             Float?
  volArbFired               Boolean  @default(false)

  createdAt DateTime @default(now())

  // Composite unique index — the idempotency constraint.
  // If the keeper crashes after execute but before this record is written,
  // on restart it will attempt the cycle again (no record found = not done).
  // If the crash is after this record, the duplicate is silently skipped.
  @@unique([portfolioId, expiryMs])
  @@index([oracleId])
  @@index([portfolioId])
}
