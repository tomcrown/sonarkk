# Sonark Frontend Environment Variables
# Copy this file to .env and fill in the values.

# Backend API URL (no trailing slash)
VITE_API_URL=http://localhost:3001

# Enoki API Key — get from https://enoki.mystenlabs.com/
# Required for zkLogin (Google sign-in). Without this, only Slush wallet is available.
VITE_ENOKI_API_KEY=REPLACE_WITH_ENOKI_API_KEY

# Google OAuth Client ID — create at https://console.cloud.google.com/
# Required for zkLogin. Set authorized redirect URI to: http://localhost:5173/auth/callback
VITE_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID

# Sui network (testnet | mainnet)
VITE_SUI_NETWORK=testnet
