{
  "name": "sonarkk",
  "version": "0.0.0",
  "private": true,
  "description": "Sonark — automated strategy platform on DeepBook Predict (Sui testnet)",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "smoke": "npm run smoke --workspace=packages/core"
  },
  "overrides": {
    "rollup": "^4.20.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "rollup": "^4.20.0",
    "typescript": "^5.5.0"
  }
}
